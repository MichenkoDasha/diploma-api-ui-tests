{
  "name": "guru",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "debug": "npx playwright test --debug",
    "tag:ui": "npx playwright test --grep @ui",
    "tag:api": "npx playwright test --grep @api",
    "allureGenerate": "npx allure generate allure-results -o allure-report --clean",
    "allureOpen": "npx allure open allure-report",
    "report:publish": "npm run allureGenerate && mkdir -p docs && cp -r allure-report/* docs/ && git add docs/ && git commit -m 'Update Allure report' && git push origin main"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^7.6.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.3.0",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.9.0",
    "dotenv": "^17.4.2"
  }
}
